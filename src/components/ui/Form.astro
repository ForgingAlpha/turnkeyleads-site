---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { 
  inputs, 
  textarea, 
  disclaimer, 
  button = 'Contact us', 
  description = '',
  action = '/thank-you',
  method = 'POST',
  name = 'contact-form',
  hasFiles = false,
  formId = `form-${name?.replace(/[^a-z0-9]/gi, '') || 'contact'}`,
} = Astro.props;

const encType = hasFiles ? "multipart/form-data" : "application/x-www-form-urlencoded";
---

<form 
  action={action} 
  method={method} 
  id={formId}
  name={name}
  data-netlify="true" 
  data-netlify-honeypot="bot-field"
  enctype={encType}
>
  {/* Netlify form name field */}
  <input type="hidden" name="form-name" value={name} />
  
  {/* Honeypot for spam protection */}
  <p class="hidden">
    <label>Don't fill this out: <input name="bot-field" /></label>
  </p>

  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '', required = false }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={`${formId}-${name}`} class="block text-sm font-medium">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={`${formId}-${name}`}
                autocomplete={autocomplete}
                placeholder={placeholder}
                required={type === 'email' || name === 'name' || required === true ? true : false}
                class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 bg-white"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for={`${formId}-textarea`} class="block text-sm font-medium">
          {textarea.label}
        </label>
        <textarea
          id={`${formId}-textarea`}
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          required={textarea.required || false}
          class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 bg-white"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id={`${formId}-disclaimer`}
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 h-4 w-4 rounded border border-gray-300 text-blue-600 focus:ring-blue-500"
            required={disclaimer.required || false}
          />
        </div>
        <div class="ml-3">
          <label for={`${formId}-disclaimer`} class="cursor-pointer select-none text-sm text-gray-600">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600">{description}</p>
      </div>
    )
  }
</form>
