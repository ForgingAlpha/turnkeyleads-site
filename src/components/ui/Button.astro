---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import type { CallToAction as Props } from '~/types';

type ButtonVariant = 'primary' | 'secondary' | 'tertiary' | 'link';

const {
  variant = 'secondary' as ButtonVariant,
  target,
  text = await Astro.slots.render('default'),
  icon = '',
  class: className = '',
  type = 'button',
  ...rest
} = Astro.props;

// Add noopener noreferrer to all external links for security
const secureRel = target === '_blank' ? 'noopener noreferrer' : undefined;

// Define class names directly without using variant mapping
const getButtonClass = (variant: ButtonVariant): string => {
  switch (variant) {
    case 'primary':
      return 'primary-button'; // Use our scoped CSS class for primary style
    case 'secondary':
      return 'btn bg-gray-50 font-medium hover:bg-gray-100 hover:border-gray-600 transition-colors duration-200';
    case 'tertiary':
      return 'btn border-none shadow-none text-muted hover:text-gray-900 transition-colors duration-200';
    case 'link':
      return 'cursor-pointer hover:text-blue-700 transition-colors duration-200';
    default:
      return 'btn bg-gray-50 font-medium'; // Fallback to secondary style
  }
};

// Get the appropriate class based on variant and merge with any custom classes
const finalClass = twMerge(getButtonClass(variant as ButtonVariant), className);
---

{
  rest.href ? (
    <a
      class={finalClass}
      href={rest.href}
      {...(target ? { target, rel: secureRel } : {})}
      {...rest}
    >
      <slot>
        {text}
      </slot>
      {icon && <Icon name={icon} class="w-5 h-5 ml-1 -mr-1.5 rtl:mr-1 rtl:-ml-1.5 inline-block" />}
    </a>
  ) : (
    <button 
      type={type} 
      class={finalClass}
      {...rest}
    >
      <slot>
        {text}
      </slot>
      {icon && <Icon name={icon} class="w-5 h-5 ml-1 -mr-1.5 rtl:mr-1 rtl:-ml-1.5 inline-block" />}
    </button>
  )
}

<style>
  /* Primary button styles with hover effect */
  .primary-button {
    background-color: #0161ef !important;
    color: white !important;
    border-color: #0161ef !important;
    border-width: 1px !important;
    border-style: solid !important;
    font-weight: bold !important;
    opacity: 1 !important;
    visibility: visible !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 9999px !important;
    padding: 0.875rem 1.5rem !important;
    cursor: pointer !important;
    transition: background-color 0.2s, border-color 0.2s !important;
  }

  .primary-button:hover {
    background-color: #0154cf !important;
    border-color: #0154cf !important;
  }

  @media (min-width: 768px) {
    .primary-button {
      padding: 0.875rem 2rem !important;
    }
  }
</style>