---
import Layout from '~/layouts/Layout.astro';
import Logo from '~/components/Logo.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';

const metadata = {
  title: "You're on the list | Turnkey Leads",
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <!-- Minimal Header -->
  <header class="w-full py-4 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto flex justify-center">
      <a href="/" class="flex items-center">
        <Logo />
      </a>
    </div>
  </header>

  <main>
    <section class="py-16 md:py-24">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <!-- Success Icon -->
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 text-green-600 mb-6">
          <Icon name="tabler:check" class="w-8 h-8" />
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          You're on the list!
        </h1>
        <p class="text-lg text-gray-600 mb-10">
          We'll notify you as soon as early access opens. In the meantime, help us build the right product for you.
        </p>

        <!-- Optional Qualifying Info -->
        <div class="bg-gray-50 rounded-xl p-8 text-left max-w-md mx-auto">
          <h2 class="text-lg font-semibold text-gray-900 mb-1">
            Tell us a bit more <span class="text-gray-400 font-normal">(optional)</span>
          </h2>
          <p class="text-sm text-gray-500 mb-6">This helps us prioritize features for launch.</p>

          <form
            action="/thank-you"
            method="POST"
            name="waitlist-qualify"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="waitlist-qualify" />
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="mb-4">
              <label for="market" class="block text-sm font-medium text-gray-700 mb-1">
                What market are you in?
              </label>
              <input
                type="text"
                name="market"
                id="market"
                placeholder="e.g. Phoenix, AZ"
                class="w-full py-2.5 px-4 text-sm rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <div class="mb-4">
              <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">
                Monthly marketing budget?
              </label>
              <select
                name="budget"
                id="budget"
                class="w-full py-2.5 px-4 text-sm rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
                <option value="">Select one...</option>
                <option value="under-500">Under $500</option>
                <option value="500-2000">$500 – $2,000</option>
                <option value="2000-5000">$2,000 – $5,000</option>
                <option value="5000-plus">$5,000+</option>
              </select>
            </div>

            <div class="mb-6">
              <label for="deals" class="block text-sm font-medium text-gray-700 mb-1">
                Deals closed last year?
              </label>
              <select
                name="deals"
                id="deals"
                class="w-full py-2.5 px-4 text-sm rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              >
                <option value="">Select one...</option>
                <option value="0-5">0 – 5</option>
                <option value="6-15">6 – 15</option>
                <option value="16-30">16 – 30</option>
                <option value="30-plus">30+</option>
              </select>
            </div>

            <button
              type="submit"
              class="qualify-btn w-full py-2.5 px-6 text-sm font-semibold rounded-lg"
            >
              Submit
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <!-- Minimal Footer -->
  <footer class="py-8 px-4 sm:px-6 border-t border-gray-200">
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} {SITE?.name}. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>

<style>
  .qualify-btn {
    background-color: #0161ef;
    color: white;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .qualify-btn:hover {
    background-color: #0154cf;
  }
</style>
