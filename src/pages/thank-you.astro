---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Thank You | TurnKey Leads',
};
---

<Layout metadata={metadata}>
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter mb-6">Thank You!</h1>
      <p class="text-xl text-gray-700 mb-8">
        We've received your information and will be in touch soon.
      </p>
      <div class="mt-8">
        <a href="/" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-full inline-block">
          Return to Homepage
        </a>
      </div>
    </div>
  </section>
</Layout>