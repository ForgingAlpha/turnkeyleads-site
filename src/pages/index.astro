---
import Layout from '~/layouts/Layout.astro';
import Logo from '~/components/Logo.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';

const metadata = {
  title: 'Turnkey Leads — AI-Powered Marketing for Real Estate Agents',
  description: 'Pick a location. Set a budget. AI does the rest. Join the waitlist for the autopilot marketing platform built for real estate agents.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Minimal Header — Logo only, no nav -->
  <header class="w-full py-4 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto flex justify-center">
      <a href="/" class="flex items-center">
        <Logo />
      </a>
    </div>
  </header>

  <main>
    <!-- ========== HERO — Above the Fold ========== -->
    <section class="relative pt-8 pb-16 md:pt-16 md:pb-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-sm font-semibold tracking-widest uppercase text-blue-600 mb-4">
          Coming Soon
        </p>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight tracking-tighter mb-6 text-gray-900">
          Pick a location. Set a budget.<br />
          <span class="text-blue-600">AI does the rest.</span>
        </h1>

        <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto mb-10">
          The autopilot marketing platform for real estate agents. AI builds your ads, optimizes your spend, and delivers leads that are exclusively yours.
        </p>

        <!-- Email Capture Form -->
        <form
          action="/thank-you"
          method="POST"
          name="waitlist"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="max-w-lg mx-auto"
        >
          <input type="hidden" name="form-name" value="waitlist" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              name="email"
              required
              placeholder="Enter your email"
              autocomplete="email"
              class="flex-1 py-3.5 px-5 text-base rounded-full border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
            <button
              type="submit"
              class="waitlist-btn py-3.5 px-8 text-base font-semibold rounded-full whitespace-nowrap"
            >
              Get Early Access
            </button>
          </div>
          <p class="mt-3 text-sm text-gray-500">
            Join the waitlist. No spam, ever.
          </p>
        </form>
      </div>
    </section>

    <!-- ========== THE PROBLEM ========== -->
    <section class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900">
          Growth shouldn't require more hours
        </h2>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center md:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-red-100 text-red-600 mb-4">
              <Icon name="tabler:chart-line" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Unpredictable income</h3>
            <p class="text-gray-600">
              Referrals come in waves. Some months are great; others are stressful. You don't have a consistent way to fill the pipeline.
            </p>
          </div>

          <div class="text-center md:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-red-100 text-red-600 mb-4">
              <Icon name="tabler:clock" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">No time for marketing</h3>
            <p class="text-gray-600">
              You know you should be running ads and staying visible. But you're busy showing homes and closing deals.
            </p>
          </div>

          <div class="text-center md:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-red-100 text-red-600 mb-4">
              <Icon name="tabler:refresh" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Effort doesn't compound</h3>
            <p class="text-gray-600">
              You work hard, but too much of it resets every month. You want a system that builds on itself.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== THE SOLUTION — 3 Benefits ========== -->
    <section class="py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-gray-900">
          A system that runs without you
        </h2>
        <p class="text-lg text-gray-600 text-center max-w-2xl mx-auto mb-12">
          Set your goal. Set your budget. AI builds your campaigns, optimizes your spend, and delivers leads that are exclusively yours.
        </p>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-600 mb-4">
              <Icon name="tabler:sparkles" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">AI builds your ads</h3>
            <p class="text-gray-600">
              Video, images, carousels, landing pages. No agencies, no guesswork, no learning Facebook Ads Manager.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-600 mb-4">
              <Icon name="tabler:lock" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Your leads are yours</h3>
            <p class="text-gray-600">
              Every lead is exclusively yours for 18 months. We never resell or share with other agents. Your pipeline compounds.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-600 mb-4">
              <Icon name="tabler:coin" class="w-6 h-6" />
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Your budget works harder</h3>
            <p class="text-gray-600">
              More of every dollar goes to actual ads — not middlemen. AI continuously optimizes to get you the best results.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== HOW IT WORKS ========== -->
    <section class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900">
          How it works
        </h2>

        <div class="grid md:grid-cols-3 gap-8 text-center">
          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-blue-600 text-white text-xl font-bold mb-4">
              1
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Choose your goal</h3>
            <p class="text-gray-600">
              Get listings, attract buyers, or promote a property. One goal, one budget.
            </p>
          </div>

          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-blue-600 text-white text-xl font-bold mb-4">
              2
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">Set your budget</h3>
            <p class="text-gray-600">
              See your forecast instantly. AI creative is included — no hidden fees.
            </p>
          </div>

          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-blue-600 text-white text-xl font-bold mb-4">
              3
            </div>
            <h3 class="text-lg font-semibold mb-2 text-gray-900">AI handles the rest</h3>
            <p class="text-gray-600">
              Creative, targeting, optimization, lead delivery. You focus on closing.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TESTIMONIALS ========== -->
    <section class="py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900">
          What agents are saying
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
            <div class="flex items-center gap-1 mb-4">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="tabler:star-filled" class="w-5 h-5 text-yellow-400" />
              ))}
            </div>
            <blockquote class="text-gray-700 mb-4">
              "I finally have something running in the background. Leads come in, I work them on my schedule, and I'm not scrambling during slow months."
            </blockquote>
            <div>
              <p class="font-semibold text-gray-900">Sarah J.</p>
              <p class="text-sm text-gray-500">Real Estate Agent, Austin TX</p>
            </div>
          </div>

          <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
            <div class="flex items-center gap-1 mb-4">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="tabler:star-filled" class="w-5 h-5 text-yellow-400" />
              ))}
            </div>
            <blockquote class="text-gray-700 mb-4">
              "I was working 60-hour weeks and knew it wasn't sustainable. Now the AI handles my marketing and I focus on what I'm good at — closing."
            </blockquote>
            <div>
              <p class="font-semibold text-gray-900">Mike R.</p>
              <p class="text-sm text-gray-500">Real Estate Agent, Miami FL</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== BOTTOM CTA ========== -->
    <section class="py-16 md:py-24 bg-blue-600">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Grow without working more
        </h2>
        <p class="text-lg text-blue-100 mb-10 max-w-xl mx-auto">
          You're already good at what you do. This gives you leverage — a system that fills the pipeline while you focus on closing.
        </p>

        <!-- Second Email Capture Form -->
        <form
          action="/thank-you"
          method="POST"
          name="waitlist"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="max-w-lg mx-auto"
        >
          <input type="hidden" name="form-name" value="waitlist" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              name="email"
              required
              placeholder="Enter your email"
              autocomplete="email"
              class="flex-1 py-3.5 px-5 text-base rounded-full border-2 border-blue-400 bg-white focus:outline-none focus:ring-2 focus:ring-white focus:border-transparent"
            />
            <button
              type="submit"
              class="py-3.5 px-8 text-base font-semibold rounded-full whitespace-nowrap bg-white text-blue-600 hover:bg-blue-50 transition-colors duration-200 cursor-pointer"
            >
              Get Early Access
            </button>
          </div>
          <p class="mt-3 text-sm text-blue-200">
            Cancel anytime. No long-term contracts. Leads yours for 18 months.
          </p>
        </form>
      </div>
    </section>
  </main>

  <!-- Minimal Footer -->
  <footer class="py-8 px-4 sm:px-6 border-t border-gray-200">
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} {SITE?.name}. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>

<style>
  .waitlist-btn {
    background-color: #0161ef;
    color: white;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .waitlist-btn:hover {
    background-color: #0154cf;
  }
</style>
