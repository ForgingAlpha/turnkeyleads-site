---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Turnkey Leads',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Us"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=2070&q=80',
      alt: 'Turnkey Leads',
    }}
  >
    <Fragment slot="title">
      Your Real Estate Lead Generation, <br />
      <span class="text-accent dark:text-white highlight"> Simplified</span>
    </Fragment>

    <Fragment slot="subtitle">
      Turnkey Leads provides effortless lead generation services for realtors and brokerages. We manage marketing, lead capture, and delivery—so you can focus on closing deals.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->


  <!-- Steps2 Widget - Values ****************** -->

  <Steps2
    title="Our Values"
    subtitle="We are driven by principles that put your success first."
    items={[
      {
        title: 'Customer-centric Approach',
        description:
          'Everything we do revolves around providing value and results for real estate professionals. Your success defines ours.',
      },
      {
        title: 'Constant Improvement',
        description:
          'We continually refine our strategies to ensure your leads are always fresh, relevant, and highly targeted.',
      },
      {
        title: 'Ethical Practices',
        description:
          'Integrity and transparency guide our interactions, ensuring your trust in every aspect of our service.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Why Choose Us"
    subtitle="Turnkey Leads takes the hassle out of lead generation, allowing you to focus on closing deals."
    isReversed={true}
    callToAction={{
      text: 'Get Started',
      href: '/contact',
    }}
    items={[
      {
        title: 'Full-Service Marketing',
        description: 'From advertising campaigns to lead capture, we manage it all seamlessly for you.',
        icon: 'tabler:check',
      },
      {
        title: 'No Contracts, Just Results',
        description:
          'We never lock you into contracts. We believe in proving our value month after month with consistent results.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Nationwide Coverage',
        description:
          'Based in North Pittsburgh, PA, we proudly serve real estate professionals throughout the United States.',
        icon: 'tabler:globe',
      },
    ]}
    callToAction={{
      text: 'Get Started',
      href: '/contact',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Get in Touch"
    tagline="We're here to help"
    columns={2}
    items={[
      {
        title: 'Email Support',
        description: 'Reach out anytime at support@turnkeyleads.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Call Us',
        description:
          'For immediate assistance, reach out via phone and speak directly with our support team.',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>

